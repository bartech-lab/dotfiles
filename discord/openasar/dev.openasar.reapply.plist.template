<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.openasar.reapply</string>

  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/dotfiles/discord/openasar/reapply-openasar.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>DISCORD_APP_PATH</key>
    <string>__DISCORD_APP_PATH__</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>WatchPaths</key>
  <array>
    <string>__DISCORD_APP_PATH__/Contents/Resources/app.asar</string>
    <string>__DISCORD_APP_PATH__/Contents/Resources/build_info.json</string>
  </array>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/OpenAsarPersist/launchagent.out.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/OpenAsarPersist/launchagent.err.log</string>
</dict>
</plist>
